{
	"schemaVersion": 1,
	"id": "stasisbot",
	"version": "${version}",
	"name": "StasisBot",
	"description": "A 2b2t home-bot utility: detects stasis chambers, watches their ender pearls, and fires the right one when a friend asks for it in chat.",
	"authors": [
		"NyuDev"
	],
	"contact": {
		"homepage": "https://github.com/NyuDev",
		"sources": "https://github.com/NyuDev"
	},
	"license": "MIT",
	"environment": "client",
	"entrypoints": {
		"client": [
			"fr.nyuway.stasisbot.StasisBotClient"
		]
	},
	"depends": {
		"fabricloader": ">=0.16.0",
		"minecraft": "${minecraft_version}",
		"java": ">=21",
		"fabric-api": "*"
	}
}
